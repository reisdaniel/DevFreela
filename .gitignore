# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/

# Enable "build/" folder in the NuGet Packages folder since NuGet Packages uses it for MSBuild targets
!packages/build/

# Local configurations
*.config
*.Development.json

# Visual Studio specific files
.vs/
.vscode/
.idea/
.vscode/
*.vsix
.vsconfig

# Ignore specific files and directories
DevFreela.API/Controllers/WeatherForecastController.cs
DevFreela.API/DevFreela.API.http
DevFreela.API/Properties/launchSettings.json
DevFreela.API/WeatherForecast.cs
